---
import Base from "./Base.astro";

interface Props {
  title: string;
  date: string;
  garmin_id?: string;
  distance_km: number;
  duration_seconds: number;
  pace_per_km: string;
  avg_hr?: number | null;
  city?: string | null;
  country?: string | null;
  has_route?: boolean;
}

const {
  title,
  date,
  garmin_id,
  distance_km,
  duration_seconds,
  pace_per_km,
  avg_hr,
  city,
  country,
  has_route = false,
} = Astro.props;

function formatDuration(seconds: number): string {
  const h = Math.floor(seconds / 3600);
  const m = Math.floor((seconds % 3600) / 60);
  const s = seconds % 60;
  if (h > 0) {
    return `${h}:${String(m).padStart(2, "0")}:${String(s).padStart(2, "0")}`;
  }
  return `${m}:${String(s).padStart(2, "0")}`;
}

function formatDate(d: string): string {
  return new Date(d + "T00:00:00").toLocaleDateString("en-GB", {
    day: "numeric",
    month: "long",
    year: "numeric",
  });
}

const location = [city, country].filter(Boolean).join(", ");
const showMap = has_route && !!garmin_id;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Base title={title} leafletCss={showMap}>

  <div class="run-header">
    <p class="label">{formatDate(date)}{location ? ` · ${location}` : ""}</p>
    <h1>{title}</h1>
  </div>

  <div class="stats-grid">
    <div class="stat">
      <span class="label">Distance</span>
      <span class="metric">{distance_km.toFixed(1)} km</span>
    </div>
    <div class="stat">
      <span class="label">Time</span>
      <span class="metric">{formatDuration(duration_seconds)}</span>
    </div>
    <div class="stat">
      <span class="label">Pace</span>
      <span class="metric">{pace_per_km}/km</span>
    </div>
    {avg_hr && (
      <div class="stat">
        <span class="label">Avg HR</span>
        <span class="metric">{avg_hr} bpm</span>
      </div>
    )}
  </div>

  {showMap && (
    <div id="route-map"></div>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" is:inline></script>
    <script define:vars={{ garmin_id, base }}>
      window.addEventListener("load", function () {
        var mapEl = document.getElementById("route-map");
        if (!mapEl) return;

        fetch(base + "/routes/" + garmin_id + ".json")
          .then(function (r) { return r.json(); })
          .then(function (coords) {
            if (!coords || coords.length === 0) {
              mapEl.style.display = "none";
              return;
            }
            var map = L.map("route-map");
            L.tileLayer(
              "https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png",
              {
                attribution: "&copy; OpenStreetMap contributors &copy; CARTO",
                maxZoom: 19,
              }
            ).addTo(map);
            var line = L.polyline(coords, { color: "#111111", weight: 2, opacity: 1 });
            line.addTo(map);
            map.fitBounds(line.getBounds(), { padding: [20, 20] });
          })
          .catch(function () {
            mapEl.style.display = "none";
          });
      });
    </script>
  )}

  <div class="run-body">
    <slot />
  </div>
</Base>

<style>
  .run-header {
    margin-bottom: 2rem;
  }
  .run-header h1 {
    margin: 0.25rem 0 0;
    font-size: 1.75rem;
    font-weight: 500;
  }
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding: 1.25rem 0;
    margin-bottom: 2rem;
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .stat .metric {
    font-size: 1.1rem;
  }
  #route-map {
    width: 100%;
    height: 300px;
    border: 1px solid var(--line);
    margin: 2rem 0;
  }
  .run-body {
    max-width: 640px;
  }
  @media (max-width: 480px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
