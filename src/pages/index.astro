---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import MonthGrid from "../components/MonthGrid.astro";
import { readFileSync } from "node:fs";
import path from "node:path";

const allRuns = await getCollection("runs");
const allPosts = await getCollection("posts");

allRuns.sort((a, b) => b.data.date.localeCompare(a.data.date));
allPosts.sort((a, b) => b.data.date.localeCompare(a.data.date));

const latestRun = allRuns[0];

const now = new Date();
const currentYear = now.getFullYear();
const currentMonth = now.getMonth() + 1;
const currentYM = `${currentYear}-${String(currentMonth).padStart(2, "0")}`;

const thisMonthRuns = allRuns.filter((r) => r.data.date.startsWith(currentYM));

const prevYear = currentMonth === 1 ? currentYear - 1 : currentYear;
const prevMonth = currentMonth === 1 ? 12 : currentMonth - 1;
const prevYM = `${prevYear}-${String(prevMonth).padStart(2, "0")}`;
const prevMonthRuns = allRuns.filter((r) => r.data.date.startsWith(prevYM));

let stats: { pb_5k: string | null; pb_10k: string | null; pb_half: string | null; current_streak: number } = {
  pb_5k: null,
  pb_10k: null,
  pb_half: null,
  current_streak: 0,
};

try {
  const statsPath = path.join(process.cwd(), "data", "stats.json");
  const raw = readFileSync(statsPath, "utf-8");
  stats = JSON.parse(raw);
} catch {
  // file missing or invalid — use defaults
}

const recentPosts = allPosts.slice(0, 3);

const gridActivities = thisMonthRuns.map((r) => ({
  date: r.data.date,
  distance_km: r.data.distance_km,
  slug: r.id,
}));

const prevGridActivities = prevMonthRuns.map((r) => ({
  date: r.data.date,
  distance_km: r.data.distance_km,
  slug: r.id,
}));
---

<Base title="Home">
  <section class="home-section streak-hero">
    <p class="label">Current streak</p>
    <p class="streak-number">{stats.current_streak} <span class="streak-unit">days</span></p>
  </section>

  {latestRun && (
    <section class="home-section">
      <p class="label">Latest run</p>
      <a href={`/runs/${latestRun.id}`} class="run-entry">
        <div class="run-top">
          <span class="run-title">{latestRun.data.title}</span>
          <span class="run-date">{new Date(latestRun.data.date + "T00:00:00").toLocaleDateString("en-GB", { day: "2-digit", month: "short" })}</span>
        </div>
        <div class="run-stats">
          <span>
            <span class="label">Dist</span>
            <span class="metric">{latestRun.data.distance_km} km</span>
          </span>
          <span>
            <span class="label">Pace</span>
            <span class="metric">{latestRun.data.pace_per_km}/km</span>
          </span>
          {latestRun.data.avg_hr && (
            <span>
              <span class="label">HR</span>
              <span class="metric">{latestRun.data.avg_hr} bpm</span>
            </span>
          )}
          {latestRun.data.city && (
            <span>
              <span class="label">City</span>
              <span class="metric">{latestRun.data.city}</span>
            </span>
          )}
        </div>
      </a>
    </section>
  )}

  <section class="home-section">
    <p class="label">Activity</p>
    <MonthGrid year={currentYear} month={currentMonth} activities={gridActivities} />
    <div class="grid-gap" />
    <MonthGrid year={prevYear} month={prevMonth} activities={prevGridActivities} />
  </section>

  <section class="home-section">
    <p class="label">Best efforts</p>
    <div class="best-efforts">
      <div>
        <span class="label">5K</span>
        <span class="metric">{stats.pb_5k ?? "—"}</span>
      </div>
      <div>
        <span class="label">10K</span>
        <span class="metric">{stats.pb_10k ?? "—"}</span>
      </div>
      <div>
        <span class="label">Half marathon</span>
        <span class="metric">{stats.pb_half ?? "—"}</span>
      </div>
    </div>
  </section>

  {recentPosts.length > 0 && (
    <section class="home-section">
      <p class="label">Recent notes</p>
      <ul class="post-list">
        {recentPosts.map((p) => (
          <li>
            <a href={`/posts/${p.id}`}>{p.data.title}</a>
          </li>
        ))}
      </ul>
    </section>
  )}
</Base>

<style>
  .home-section {
    margin-bottom: 3rem;
  }
  .home-section > .label {
    display: block;
    margin-bottom: 0.75rem;
  }
  .grid-gap {
    height: 1.5rem;
  }
  .best-efforts {
    display: flex;
    gap: 3rem;
  }
  .best-efforts > div {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .best-efforts .metric {
    font-size: 1.2rem;
  }
  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
</style>
