---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const allRuns = await getCollection("runs");
allRuns.sort((a, b) => b.data.date.localeCompare(a.data.date));

function formatDay(d: string): string {
  return new Date(d + "T00:00:00").toLocaleDateString("en-GB", {
    day: "2-digit",
    month: "short",
  });
}

function monthLabel(d: string): string {
  const dt = new Date(d + "T00:00:00");
  return dt.toLocaleDateString("en-GB", { month: "long", year: "numeric" }).toUpperCase();
}

const groups = new Map<string, typeof allRuns>();
for (const run of allRuns) {
  const key = run.data.date.slice(0, 7);
  if (!groups.has(key)) groups.set(key, []);
  groups.get(key)!.push(run);
}

const sortedKeys = [...groups.keys()].sort((a, b) => b.localeCompare(a));
---

<Base title="Runs">
  {sortedKeys.map((key) => {
    const runs = groups.get(key)!;
    const label = monthLabel(runs[0].data.date);
    return (
      <section class="month-section">
        <p class="month-heading">{label}</p>
        {runs.map((r) => (
          <a href={`${base}/runs/${r.id}`} class="run-entry">
            <div class="run-top">
              <span class="run-title">{r.data.title}</span>
              <span class="run-date">{formatDay(r.data.date)}</span>
            </div>
            <div class="run-stats">
              <span>
                <span class="stat-label">Dist</span>
                <span class="metric">{r.data.distance_km.toFixed(1)} km</span>
              </span>
              <span>
                <span class="stat-label">Pace</span>
                <span class="metric">{r.data.pace_per_km}/km</span>
              </span>
              {r.data.city && (
                <span>
                  <span class="stat-label">City</span>
                  <span class="metric">{r.data.city}</span>
                </span>
              )}
            </div>
          </a>
        ))}
      </section>
    );
  })}
</Base>

<style>
  .month-section {
    margin-bottom: 0.5rem;
  }
  .month-heading {
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 1.5rem 0 0.5rem;
    border-bottom: 1px solid var(--line);
    margin: 0;
  }
  .run-entry {
    display: block;
    border-bottom: 1px solid var(--line);
    padding: 0.875rem 0;
    text-decoration: none;
    color: inherit;
  }
  .run-entry:hover {
    background: var(--soft);
  }
  .run-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.4rem;
  }
  .run-title {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text);
  }
  .run-date {
    font-size: 0.8rem;
    color: var(--muted);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    flex-shrink: 0;
    margin-left: 1rem;
  }
  .run-stats {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .run-stats > span {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .stat-label {
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .run-stats .metric {
    font-size: 0.85rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    color: var(--text);
  }
</style>
