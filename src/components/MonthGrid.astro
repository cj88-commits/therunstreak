---
interface Activity {
  date: string;
  distance_km: number;
  slug: string;
}

interface Props {
  year: number;
  month: number;
  activities: Activity[];
}

const { year, month, activities } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const today = new Date();
today.setHours(0, 0, 0, 0);

const daysInMonth = new Date(year, month, 0).getDate();

const firstDay = new Date(year, month - 1, 1).getDay();
const startOffset = firstDay === 0 ? 6 : firstDay - 1;

const monthNames = [
  "January","February","March","April","May","June",
  "July","August","September","October","November","December",
];
const monthLabel = `${monthNames[month - 1].toUpperCase()} ${year}`;

// Sum distance per day (supports multiple runs on same day)
const dayMap = new Map<string, { totalKm: number; slug: string }>();
for (const a of activities) {
  const existing = dayMap.get(a.date);
  if (existing) {
    existing.totalKm += a.distance_km;
  } else {
    dayMap.set(a.date, { totalKm: a.distance_km, slug: a.slug });
  }
}

function shadeForKm(km: number): string {
  if (km >= 18.0) return "#000000";
  if (km >= 12.0) return "#262626";
  if (km >= 8.0)  return "#525252";
  if (km >= 5.0)  return "#a3a3a3";
  return "#d4d4d4";
}

interface Cell {
  day: number | null;
  dateStr: string | null;
  totalKm: number;
  slug: string | null;
  isFuture: boolean;
}

const cells: Cell[] = [];

for (let i = 0; i < startOffset; i++) {
  cells.push({ day: null, dateStr: null, totalKm: 0, slug: null, isFuture: false });
}

for (let d = 1; d <= daysInMonth; d++) {
  const dateStr = `${year}-${String(month).padStart(2, "0")}-${String(d).padStart(2, "0")}`;
  const cellDate = new Date(year, month - 1, d);
  const isFuture = cellDate > today;
  const data = dayMap.get(dateStr);
  cells.push({
    day: d,
    dateStr,
    totalKm: data?.totalKm ?? 0,
    slug: data?.slug ?? null,
    isFuture,
  });
}

const totalRuns = activities.length;
const totalKm = activities.reduce((s, a) => s + a.distance_km, 0);
---

<div class="month-grid-wrapper">
  <p class="label month-title">{monthLabel}</p>
  <div class="day-headers">
    {["Mo","Tu","We","Th","Fr","Sa","Su"].map((d) => (
      <span class="day-header label">{d}</span>
    ))}
  </div>
  <div class="grid">
    {cells.map((cell) => {
      if (cell.day === null) {
        return <div class="cell empty" />;
      }
      if (cell.isFuture) {
        return <div class="cell future" title={cell.dateStr ?? ""} />;
      }
      if (cell.totalKm > 0 && cell.slug) {
        const shade = shadeForKm(cell.totalKm);
        const shortDate = `${String(cell.day).padStart(2, "0")} ${monthNames[month - 1].slice(0, 3)}`;
        return (
          <a
            href={`${base}/runs/${cell.slug}`}
            class="cell run"
            style={`background:${shade}`}
            title={`${shortDate} · ${cell.totalKm.toFixed(1)} km`}
          />
        );
      }
      return <div class="cell no-run" title={cell.dateStr ?? ""} />;
    })}
  </div>
  <p class="label summary">{totalRuns} run{totalRuns !== 1 ? "s" : ""} · {totalKm.toFixed(1)} km</p>
</div>

<style>
  .month-grid-wrapper {
    display: inline-block;
  }
  .month-title {
    margin: 0 0 0.5rem;
  }
  .day-headers {
    display: grid;
    grid-template-columns: repeat(7, 1.5rem);
    gap: 3px;
    margin-bottom: 3px;
  }
  .day-header {
    width: 1.5rem;
    text-align: center;
    font-size: 0.6rem;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(7, 1.5rem);
    gap: 3px;
  }
  .cell {
    width: 1.5rem;
    height: 1.5rem;
    display: block;
  }
  .cell.empty {
    background: transparent;
  }
  .cell.run {
    /* background set via inline style */
  }
  .cell.no-run {
    border: 1px solid var(--line);
    background: transparent;
  }
  .cell.future {
    background: #f5f5f5;
    border: 1px solid var(--line);
  }
  .summary {
    margin: 0.5rem 0 0;
  }
</style>
